# Iris Docker Environment Variables
# Copy this file to .env and uncomment the values you need.
#
# LLM API keys are configured in the data volume at configs/llm.yaml, not here.
# After first start, edit: docker compose exec iris vi /data/configs/llm.yaml

# ---- General ----

# Platform(s) to run (comma-separated: web, discord, telegram, lark, wxwork, weixin, qq)
# Note: 'console' is NOT available in the Docker image (it requires the Bun runtime).
# IRIS_PLATFORM=web

# Host port mapping (default: 8192)
# IRIS_PORT=8192

# ---- Web Platform ----

# API authentication token (recommended for public deployments)
# WEB_AUTH_TOKEN=

# Management API token (for /api/config, /api/deploy)
# WEB_MANAGEMENT_TOKEN=

# ---- Discord ----
# DISCORD_TOKEN=

# ---- Telegram ----
# TELEGRAM_TOKEN=

# ---- Lark (Feishu) ----
# LARK_APP_ID=
# LARK_APP_SECRET=

# ---- WeCom (Enterprise WeChat) ----
# WXWORK_BOT_ID=
# WXWORK_SECRET=
