{
  "name": "iris",
  "version": "1.0.0",
  "description": "模块化、可解耦的 AI 聊天框架，支持多平台、多 LLM、工具调用",
  "type": "module",
  "scripts": {
    "build": "bun run typecheck:ui && bun run build:ui && tsc -p tsconfig.build.json",
    "build:ui": "cd src/platforms/web/web-ui && npm run build",
    "typecheck:ui": "cd src/platforms/web/web-ui && npm run typecheck",
    "lint:ui": "cd src/platforms/web/web-ui && npm run lint",
    "check:ui": "cd src/platforms/web/web-ui && npm run check",
    "dev:ui": "cd src/platforms/web/web-ui && npm run dev",
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "setup": "bun install && cd src/platforms/web/web-ui && npm install",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "better-sqlite3": "^12.6.2",
    "cli-highlight": "^2.1.11",
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "marked": "^17.0.4",
    "pdf-parse": "^2.4.5",
    "react": ">=19.0.0",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "libreoffice-convert": "^1.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/react": ">=19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
