{
  "name": "iris",
  "version": "1.0.0",
  "description": "模块化、可解耦的 AI 聊天框架，支持多平台、多 LLM、工具调用",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck:ui && npm run build:ui && npx tsc -p tsconfig.build.json",
    "build:compile": "bun run script/build.ts",
    "build:ui": "cd src/platforms/web/web-ui && npm run build",
    "typecheck:ui": "cd src/platforms/web/web-ui && npm run typecheck",
    "lint:ui": "cd src/platforms/web/web-ui && npm run lint",
    "check:ui": "cd src/platforms/web/web-ui && npm run check",
    "dev:ui": "cd src/platforms/web/web-ui && npm run dev",
    "start": "tsx script/run.ts",
    "dev": "tsx script/run.ts",
    "cli": "tsx src/cli.ts",
    "cli:bun": "bun src/cli.ts",
    "start:bun": "bun script/run.ts",
    "dev:bun": "bun script/run.ts",
    "setup": "npm install --legacy-peer-deps && cd src/platforms/web/web-ui && npm install",
    "test": "vitest run"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@wecom/aibot-node-sdk": "^1.0.2",
    "better-sqlite3": "^12.6.2",
    "cli-highlight": "^2.1.11",
    "dereference-json-schema": "^0.2.2",
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "marked": "^17.0.4",
    "mime-types": "^3.0.2",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "react": ">=19.0.0",
    "sharp": "^0.34.5",
    "tokenx": "^1.3.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@opentui/core": "^0.1.88",
    "@opentui/react": "latest",
    "libreoffice-convert": "^1.8.1",
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.15",
    "@types/react": ">=19.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
